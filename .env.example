# HugoHerbots.com — Environment Variables
# Copy this file to .env and fill in the values.

# ─── Supabase (required) ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_YOUR_PASSWORD=your-db-password

# ─── Anthropic (required — powers the AI coach) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe (required for payments) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Daily.co (required for video calls) ────────────────────────────────────
DAILY_API_KEY=your-daily-api-key

# ─── Mux (required for video hosting) ───────────────────────────────────────
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# ─── Auth / Admin ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@hugoherbots.com
ADMIN_PASSWORD=your-admin-password
SESSION_SECRET=random-session-secret

# ─── Resend (email) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── LangWatch (observability, optional) ────────────────────────────────────
LANGWATCH_API_KEY=

# ─── Voice / Avatar (optional) ──────────────────────────────────────────────
ELEVENLABS_AGENT_ID=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
HEYGEN_API_KEY=
HEYGEN_LIVEAVATAR_API_KEY=
TAVUS_API_KEY=
TAVUS_PERSONA_ID=
TAVUS_REPLICA_ID=

# ─── Internal services ──────────────────────────────────────────────────────
VIDEO_PROCESSOR_SECRET=random-secret
CLOUD_RUN_WORKER_URL=
CLOUD_RUN_WORKER_SECRET=

# ─── Optional / Dev ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_CLOUD_SECRET=
GITHUB_TOKEN=
REPLICATE_API_TOKEN=
SCREENSHOT_EMAIL=
SCREENSHOT_PASSWORD=
