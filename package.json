            "vitest": "^4.0.18"
      },
      "scripts": {
            "dev": "vite",
            "build": "vite build && npx esbuild server/hugo-engine/standalone.ts --bundle --platform=node --target=node20 --outfile=server/hugo-engine/standalone.js --external:@neondatabase/serverless --external:ws --external:express --external:cors --external:openai --external:@supabase/supabase-js --external:@livekit/server-sdk --external:deepgram --external:stripe --external:ffmpeg-static --external:langwatch --external:@opentelemetry/sdk-node --external:@opentelemetry/context-async-hooks --external:@opentelemetry/api --format=cjs",
            "test:scenarios": "vitest run --config vitest.config.scenarios.ts",
            "test:scenarios:auto": "SCENARIO_AUTH_TOKEN=$(npx tsx --env-file=.env scripts/generate-test-token.ts) vitest run --config vitest.config.scenarios.ts",
            "lint": "echo 'No linter configured' && exit 0",
            "typecheck": "npx tsc --noEmit && npx tsc --noEmit -p server/hugo-engine/tsconfig.json",
            "test": "node scripts/config-lint.js",
            "config-lint": "node scripts/config-lint.js",
            "audit:screenshot": "tsx scripts/audit/screenshot-all.ts",
            "audit:report": "tsx scripts/audit/generate-report.ts",
            "audit:full": "npm run audit:screenshot && npm run audit:report",
            "dev:video-processor": "node --env-file=.env server/video-processor.js",
            "dev:backend": "npx tsx --env-file=.env server/hugo-engine/standalone.ts",
            "dev:local": "concurrently \"npm run dev\" \"npm run dev:video-processor\" \"npm run dev:backend\""
      }
}
